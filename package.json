{
  "name": "trip-planner",
  "version": "2.4.1",
  "private": true,
  "description": "A cozy, self-hosted trip board with friends-only login, an admin console, and per-trip access control.",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "build": "pkg . --targets node18-win-x64 --no-bytecode --public-packages \"*\" --public --output dist/TripPlanner.exe"
  },
  "bin": "server.js",
  "pkg": {
    "assets": [
      "public/**/*",
      "content/**/*",
      "build-info.json"
    ],
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "dist"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "express": "^4.19.2",
    "express-session": "^1.18.0",
    "session-file-store": "^1.5.0"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  }
}
