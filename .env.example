# Copy this file to ".env" only if you want to change the defaults.
# (The app works fine with no .env at all.)

# Port the site runs on. Default 4040 -> http://localhost:4040
PORT=4040

# Listen address. 0.0.0.0 lets other devices on your network (and a tunnel)
# reach it. Use 127.0.0.1 to lock it to this computer only.
HOST=0.0.0.0

# The shared code your friends type once when they create their account.
# You can also change this any time from the Admin console once it's running.
INVITE_CODE=letmein
