# Copy this file to ".env" only if you want to change the defaults.
# (The app works fine with no .env at all.)

# Port the site runs on. Default 4040 -> http://localhost:4040
PORT=4040

# Listen address. 0.0.0.0 lets other devices on your network (and a tunnel)
# reach it. Use 127.0.0.1 to lock it to this computer only.
HOST=0.0.0.0

# The shared code your friends type once when they create their account.
# You can also change this any time from the Admin console once it's running.
# Security: change this from the default before sharing the app publicly — the
# startup log will warn you while it's still the default.
INVITE_CODE=letmein

# Session signing secret. Leave unset and the app generates a strong random one
# and keeps it on disk (data/session.secret) so logins survive restarts — that's
# fine for self-hosting. Set it explicitly only if you want to pin/rotate it
# yourself (e.g. share one secret across machines). Keep it long & random.
# SESSION_SECRET=

# Max JSON request body in megabytes (default 25). This is the real upload
# ceiling for the shared drive, which sends files base64-encoded in the body
# (base64 inflates ~33%, so 25 MB allows ~18 MB raw files). Raising it widens a
# memory-DoS surface, so only bump it if you actually need bigger uploads.
# MAX_BODY_MB=25

# Set to "production" when exposing the app beyond your own machine. It tightens
# a few defaults and quiets dev-only hints.
# NODE_ENV=production
